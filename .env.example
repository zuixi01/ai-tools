# ---------- Common ----------
PROJECT_NAME=cloud-offer-watch
PROJECT_ENV=development

# ---------- Backend ----------
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
DATABASE_URL=sqlite:///./data/cloud_offer_watch.db
LOG_LEVEL=INFO
APP_TIMEZONE=Asia/Shanghai

# Scheduler (Phase 1 keeps disabled by default)
SCHEDULER_ENABLED=false
SCHEDULER_SCAN_INTERVAL_SECONDS=15
DEFAULT_POLL_INTERVAL_SECONDS=60
MAX_CONCURRENT_WATCHERS=2
GLOBAL_RATE_LIMIT_PER_MINUTE=30
ENFORCE_TARGET_POLL_INTERVAL=true

# Browser / capture
ENABLE_SCREENSHOT=true
SCREENSHOT_DIR=./captures
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=15000
PLAYWRIGHT_WAIT_UNTIL=domcontentloaded
HTML_EXCERPT_MAX_CHARS=3000

# ---------- Frontend ----------
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# ---------- Desktop ----------
DESKTOP_FRONTEND_URL=http://127.0.0.1:3000
DESKTOP_BACKEND_URL=http://127.0.0.1:8000
